{
  "name": "ai-rulebook",
  "displayName": "AI Rulebook",
  "description": "AI Rulebook — install and manage a curated AI agent rule pack for Cursor under .cursor/rules/ai-rules/, with optional Cline sync to .clinerules/ai-rules/.",
  "version": "1.2.0",
  "publisher": "WyvernSystemsLLC",
  "license": "MIT",
  "icon": "icon.png",
  "homepage": "https://github.com/wyvernsystems/ai-rulebook-vscode-extension#readme",
  "bugs": {
    "url": "https://github.com/wyvernsystems/ai-rulebook-vscode-extension/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wyvernsystems/ai-rulebook-vscode-extension.git"
  },
  "keywords": [
    "cursor",
    "cursor-rules",
    "ai",
    "ai-agent",
    "ai-rules",
    "rules",
    "rulebook",
    "cline",
    "prompt-engineering",
    "code-assistant"
  ],
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18.18.0"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiRules.installWorkspace",
        "title": "AI Rulebook: Install / update rules in workspace",
        "category": "AI Rulebook"
      },
      {
        "command": "aiRules.enableAllWorkspace",
        "title": "AI Rulebook: Enable all rules (workspace)",
        "category": "AI Rulebook"
      },
      {
        "command": "aiRules.disableAllWorkspace",
        "title": "AI Rulebook: Disable all rules (workspace)",
        "category": "AI Rulebook"
      },
      {
        "command": "aiRules.enableAllGlobal",
        "title": "AI Rulebook: Enable all rules (global mirror)",
        "category": "AI Rulebook"
      },
      {
        "command": "aiRules.disableAllGlobal",
        "title": "AI Rulebook: Disable all rules (global mirror)",
        "category": "AI Rulebook"
      },
      {
        "command": "aiRules.applyGlobalToWorkspace",
        "title": "AI Rulebook: Copy global mirror into workspace",
        "category": "AI Rulebook"
      },
      {
        "command": "aiRules.syncClineWorkspace",
        "title": "AI Rulebook: Sync bundled rules to Cline (.clinerules/ai-rules)",
        "category": "AI Rulebook"
      },
      {
        "command": "aiRules.showPackStatus",
        "title": "AI Rulebook: Show active rules (green = active)",
        "category": "AI Rulebook"
      },
      {
        "command": "aiRules.hideActiveRules",
        "title": "AI Rulebook: Hide active rules (no green)",
        "category": "AI Rulebook"
      },
      {
        "command": "aiRules.toggleIndividualRule",
        "title": "AI Rulebook: Enable or disable a single rule…",
        "category": "AI Rulebook"
      },
      {
        "command": "aiRules.resetWorkspaceRulesToDefaults",
        "title": "AI Rulebook: Reset workspace rules folder to defaults…",
        "category": "AI Rulebook"
      },
      {
        "command": "aiRules.modePlan",
        "title": "AI Rulebook: Mode — Plan (architect role, no test rules)",
        "category": "AI Rulebook"
      },
      {
        "command": "aiRules.modeBuild",
        "title": "AI Rulebook: Mode — Build (developer role, no test rules)",
        "category": "AI Rulebook"
      },
      {
        "command": "aiRules.modeTest",
        "title": "AI Rulebook: Mode — Test (tester role + all test rules)",
        "category": "AI Rulebook"
      },
      {
        "command": "aiRules.modeRole",
        "title": "AI Rulebook: Mode — Role… (pick a single role to frame replies)",
        "category": "AI Rulebook"
      },
      {
        "command": "aiRules.refreshTree",
        "title": "AI Rulebook: Refresh sidebar",
        "category": "AI Rulebook",
        "icon": "$(refresh)"
      },
      {
        "command": "aiRules.revealRuleFile",
        "title": "AI Rulebook: Open rule file",
        "category": "AI Rulebook"
      },
      {
        "command": "aiRules.enableFolder",
        "title": "AI Rulebook: Enable every rule in this folder",
        "category": "AI Rulebook",
        "icon": "$(check-all)"
      },
      {
        "command": "aiRules.disableFolder",
        "title": "AI Rulebook: Disable every rule in this folder",
        "category": "AI Rulebook",
        "icon": "$(close-all)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiRulesSidebar",
          "title": "AI Rulebook",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "aiRulesSidebar": [
        {
          "id": "aiRules.rulesTree",
          "name": "Rules",
          "icon": "$(checklist)",
          "contextualTitle": "AI Rulebook"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "aiRules.modePlan",
          "when": "view == aiRules.rulesTree",
          "group": "navigation@1"
        },
        {
          "command": "aiRules.modeBuild",
          "when": "view == aiRules.rulesTree",
          "group": "navigation@2"
        },
        {
          "command": "aiRules.modeTest",
          "when": "view == aiRules.rulesTree",
          "group": "navigation@3"
        },
        {
          "command": "aiRules.modeRole",
          "when": "view == aiRules.rulesTree",
          "group": "navigation@4"
        },
        {
          "command": "aiRules.refreshTree",
          "when": "view == aiRules.rulesTree",
          "group": "navigation@9"
        },
        {
          "command": "aiRules.enableAllWorkspace",
          "when": "view == aiRules.rulesTree",
          "group": "1_bulk@1"
        },
        {
          "command": "aiRules.disableAllWorkspace",
          "when": "view == aiRules.rulesTree",
          "group": "1_bulk@2"
        },
        {
          "command": "aiRules.installWorkspace",
          "when": "view == aiRules.rulesTree",
          "group": "2_workspace@1"
        },
        {
          "command": "aiRules.resetWorkspaceRulesToDefaults",
          "when": "view == aiRules.rulesTree",
          "group": "2_workspace@2"
        },
        {
          "command": "aiRules.showPackStatus",
          "when": "view == aiRules.rulesTree",
          "group": "3_inspect@1"
        },
        {
          "command": "aiRules.hideActiveRules",
          "when": "view == aiRules.rulesTree",
          "group": "3_inspect@2"
        }
      ],
      "view/item/context": [
        {
          "command": "aiRules.enableFolder",
          "when": "view == aiRules.rulesTree && viewItem == aiRulesFolder",
          "group": "inline@1"
        },
        {
          "command": "aiRules.disableFolder",
          "when": "view == aiRules.rulesTree && viewItem == aiRulesFolder",
          "group": "inline@2"
        },
        {
          "command": "aiRules.enableFolder",
          "when": "view == aiRules.rulesTree && viewItem == aiRulesFolder",
          "group": "1_bulk@1"
        },
        {
          "command": "aiRules.disableFolder",
          "when": "view == aiRules.rulesTree && viewItem == aiRulesFolder",
          "group": "1_bulk@2"
        }
      ]
    },
    "configuration": {
      "title": "AI Rulebook",
      "properties": {
        "aiRules.autoInstallOnOpenWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "When opening a workspace that has no .cursor/rules/ai-rules folder yet, install the bundled rule pack automatically. Existing rules folders are never overwritten."
        },
        "aiRules.colorRulesInExplorer": {
          "type": "boolean",
          "default": true,
          "description": "Tint rule files in VS Code's Explorer: `.mdc` files (active) appear green and `.mdc.disabled` files (off) appear muted gray, anywhere under `.cursor/rules/ai-rules/` in the open workspace."
        },
        "aiRules.promptInstallOnUpdate": {
          "type": "boolean",
          "default": true,
          "description": "When the extension version changes, offer to refresh workspace rules from the bundled copy."
        },
        "aiRules.autoSyncClineWhenInstalled": {
          "type": "boolean",
          "default": true,
          "description": "When Cline is installed, automatically mirror bundled .mdc rules into .clinerules/ai-rules/ after install / reset / copy-from-global (and when Cline is first detected)."
        }
      }
    }
  },
  "scripts": {
    "sync-bundled": "node scripts/sync-bundled.mjs",
    "verify:bundled": "node scripts/verify-bundled.mjs",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run sync-bundled && npm run verify:bundled && npm run compile",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
